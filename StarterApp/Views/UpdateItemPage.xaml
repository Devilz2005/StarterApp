<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StarterApp.Views.UpdateItemPage"
             Title="Update Item">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="Update Item"
                   FontSize="24"
                   FontAttributes="Bold" />

            <!-- title -->
            <Entry Placeholder="Title"
                   Text="{Binding Title}" />

            <!-- description -->
            <Editor Placeholder="Description"
                    Text="{Binding Description}"
                    AutoSize="TextChanges"
                    HeightRequest="120" />

            <!-- daily rental rate -->
            <Entry Placeholder="Daily Rate"
                   Text="{Binding DailyRate}"
                   Keyboard="Numeric" />

            <!-- category -->
            <Entry Placeholder="Category"
                   Text="{Binding Category}" />

            <!-- location -->
            <Entry Placeholder="Location"
                   Text="{Binding Location}" />

            <!-- show validation or API errors -->
            <Label Text="{Binding ErrorMessage}"
                   TextColor="Red"
                   IsVisible="{Binding HasError}" />

            <!-- action buttons -->
            <HorizontalStackLayout Spacing="10">
                <Button Text="Update Item"
                        Command="{Binding UpdateItemCommand}"
                        HorizontalOptions="FillAndExpand" />

                <Button Text="Cancel"
                        Command="{Binding CancelCommand}"
                        HorizontalOptions="FillAndExpand" />
            </HorizontalStackLayout>

            <!-- loading message while request is being sent -->
            <Label Text="Updating item..."
                   IsVisible="{Binding IsBusy}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>