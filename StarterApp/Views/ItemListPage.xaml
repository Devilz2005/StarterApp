<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StarterApp.Views.ItemListPage"
             Title="Items">

    <Grid Padding="20" RowDefinitions="Auto,Auto,Auto,Auto,Auto,*" RowSpacing="15">

        <!-- Load button -->
        <Button Grid.Row="0"
                Text="Load Items"
                Command="{Binding LoadItemsCommand}" />

        <!-- Create Item button -->
        <Button Grid.Row="1"
                Text="Create Item"
                Command="{Binding NavigateToCreateItemCommand}" />

        <!-- Rental requests button -->
        <Button Grid.Row="2"
                Text="View Rental Requests"
                Command="{Binding NavigateToRentalListCommand}" />

        <!-- Loading message -->
        <Label Grid.Row="3"
               Text="Loading..."
               IsVisible="{Binding IsLoading}" />

        <!-- Error message -->
        <Label Grid.Row="4"
               Text="{Binding ErrorMessage}"
               TextColor="Red"
               IsVisible="{Binding ErrorMessage}" />

        <!-- Scrollable item list -->
        <CollectionView Grid.Row="5"
                        ItemsSource="{Binding Items}"
                        VerticalOptions="FillAndExpand"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="12"
                           Margin="0,0,0,12"
                           BorderColor="LightGray"
                           CornerRadius="12"
                           HasShadow="False">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenItemDetailCommand}"
                                CommandParameter="{Binding .}" />
                        </Frame.GestureRecognizers>

                        <VerticalStackLayout Spacing="6">

                            <Label Text="{Binding Title}"
                                   FontAttributes="Bold"
                                   FontSize="20" />

                            <Label Text="{Binding Description}"
                                   FontSize="14"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="2" />

                            <Label Text="{Binding DailyRate, StringFormat='£{0}/day'}"
                                   TextColor="Green"
                                   FontAttributes="Bold" />

                            <Label Text="{Binding Category}"
                                   FontSize="13" />

                            <Label Text="{Binding Location}"
                                   FontSize="13" />

                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>