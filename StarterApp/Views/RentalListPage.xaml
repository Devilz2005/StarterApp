<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StarterApp.Views.RentalListPage"
             Title="Rental Requests">

    <VerticalStackLayout Padding="20" Spacing="15">

        <!-- Buttons to load either incoming or outgoing requests -->
        <HorizontalStackLayout Spacing="10">
            <Button Text="Incoming"
                    Command="{Binding LoadIncomingRentalsCommand}"
                    HorizontalOptions="FillAndExpand" />

            <Button Text="Outgoing"
                    Command="{Binding LoadOutgoingRentalsCommand}"
                    HorizontalOptions="FillAndExpand" />
        </HorizontalStackLayout>

        <!-- Loading message -->
        <Label Text="Loading rental requests..."
               IsVisible="{Binding IsBusy}" />

        <!-- Error message -->
        <Label Text="{Binding ErrorMessage}"
               TextColor="Red"
               IsVisible="{Binding HasError}" />

        <!-- Rental request list -->
        <CollectionView ItemsSource="{Binding Rentals}"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="12"
                           Margin="0,0,0,12"
                           BorderColor="LightGray"
                           CornerRadius="12"
                           HasShadow="False">
                        <VerticalStackLayout Spacing="6">

                            <Label Text="{Binding ItemTitle}"
                                   FontAttributes="Bold"
                                   FontSize="18" />

                            <Label Text="{Binding Status, StringFormat='Status: {0}'}"
                                   FontSize="14" />

                            <Label Text="{Binding StartDate, StringFormat='Start: {0:dd/MM/yyyy}'}"
                                   FontSize="14" />

                            <Label Text="{Binding EndDate, StringFormat='End: {0:dd/MM/yyyy}'}"
                                   FontSize="14" />

                            <Label Text="{Binding OwnerName, StringFormat='Owner: {0}'}"
                                   FontSize="14" />

                            <Label Text="{Binding TotalPrice, StringFormat='Total Price: £{0}'}"
                                   FontSize="14"
                                   FontAttributes="Bold" />

                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>
</ContentPage>